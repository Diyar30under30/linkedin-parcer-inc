# ─── LinkedIn credentials ───────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_ENABLED=false
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHANNEL=

# ─── Parser behaviour (optional, defaults shown) ─────────────
DELAY_MIN=3
DELAY_MAX=5
MAX_VACANCIES=20
HEADLESS=true

# ─── Auto-parsing ───────────────────────────────────────────
AUTO_PARSE_ENABLED=false
AUTO_PARSE_INTERVAL=600

# ─── System ─────────────────────────────────────────────────
SYSTEM_USER_UUID=00000000-0000-0000-0000-000000000001
